# Firebase Web App configuration. Copy this file to .env and fill values from Firebase Console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Supabase Storage for service-order attachments (free-tier alternative to Firebase Storage).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
