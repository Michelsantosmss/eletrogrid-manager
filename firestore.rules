rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    match /clients/{document} { allow read, write: if signedIn(); }
    match /equipment/{document} { allow read, write: if signedIn(); }
    match /serviceOrders/{document} { allow read, write: if signedIn(); }
    match /quotes/{document} { allow read, write: if signedIn(); }
    match /finance/{document} { allow read, write: if signedIn(); }
  }
}
